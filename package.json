{
  "name": "scottygo",
  "author": "",
  "license": "None",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmu-fse/s26-fse-scottygo.git"
  },
  "scripts": {
    "clean:dist": "rm -rf ./.dist",
    "clean:all": "rm -rf ./.parcel-cache ./.dist",
    "build": "parcel build",
    "clean:build": "npm-run-all clean:all build",
    "start": "node --max-old-space-size=320 --expose-gc ./.dist/server/serve",
    "watch": "nodemon --watch client --watch server --watch .env -e js,ts,html,pug,css,json --exec npm-run-all build start",
    "lint": "eslint ./",
    "pug": "ts-node ./tools/pug-compile",
    "serve": "ts-node server/serve",
    "test": "jest",
    "test:rest": "npm-run-all --continue-on-error test:rest:manageacct test:rest:memory-monitoring test:rest:transit test:rest:transitAPI test:rest:loginlogout",
    "test:rest:manageacct": "jest ./tests/server.tests/rest.tests/manageacct.rest.test.ts --runInBand --detectOpenHandles --coverageDirectory=.coverage/rest-manageacct",
    "test:rest:memory-monitoring": "jest ./tests/server.tests/rest.tests/memory-monitoring.rest.test.ts --runInBand --detectOpenHandles --coverageDirectory=.coverage/rest-memory-monitoring",
    "test:rest:transit": "jest ./tests/server.tests/rest.tests/transit.rest.test.ts --runInBand --detectOpenHandles --coverageDirectory=.coverage/rest-transit",
    "test:rest:transitAPI": "jest ./tests/server.tests/rest.tests/transitAPI.rest.test.ts --runInBand --detectOpenHandles --coverageDirectory=.coverage/rest-transitAPI",
    "test:rest:loginlogout": "jest ./tests/server.tests/rest.tests/loginlogout.rest.test.ts --runInBand --detectOpenHandles --coverageDirectory=.coverage/rest-loginlogout",
    "test:unit:loginlogout": "jest ./tests/server.tests/unit.tests/loginlogout.unit.test.ts --runInBand --detectOpenHandles --coverageDirectory=.coverage/unit-loginlogout",
    "test:unit:manageacct": "jest ./tests/server.tests/unit.tests/manageacct.unit.test.ts --runInBand --detectOpenHandles --coverageDirectory=.coverage/unit-manageacct",
    "test:unit": "npm-run-all test:unit:loginlogout test:unit:manageacct",
    "test:integration:manageacct": "jest ./tests/server.tests/integration.tests/manageacct.integration.test.ts --runInBand --detectOpenHandles --coverageDirectory=.coverage/integration-manageacct",
    "test:integration:loginlogout": "jest ./tests/server.tests/integration.tests/loginlogout.integration.test.ts --runInBand --detectOpenHandles --coverageDirectory=.coverage/integration-loginlogout",
    "test:integration": "npm-run-all test:integration:manageacct test:integration:loginlogout test:integration:register",
    "test:integration:register": "jest ./tests/server.tests/integration.tests/register.integration.test.ts --runInBand --detectOpenHandles --coverageDirectory=.coverage/integration-register",
    "test:server": "npm-run-all --continue-on-error test:unit test:integration test:rest",
    "later": "echo \"Some future command...\" && exit 1"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.7.2",
    "bcrypt": "^5.1.1",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "gtfs-realtime-bindings": "^1.1.1",
    "jquery": "^3.7.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.2",
    "pug": "^3.0.3",
    "resend": "^6.9.2",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "uuid": "^10.0.0"
  },
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@parcel/transformer-pug": "^2.12.0",
    "@parcel/watcher": "^2.4.1",
    "@tsconfig/node-lts": "^20.1.3",
    "@types/adm-zip": "^0.5.7",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/google.maps": "^3.58.1",
    "@types/http-terminator": "^2.0.5",
    "@types/jest": "^29.5.12",
    "@types/jquery": "^3.5.30",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.12",
    "@types/uuid": "^10.0.0",
    "assert": "^2.1.0",
    "buffer": "^6.0.3",
    "eslint": "^9.8.0",
    "globals": "^15.9.0",
    "http-terminator": "^3.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-expect-message": "^1.1.3",
    "nodemon": "^3.1.4",
    "npm": "^10.8.0",
    "npm-run-all": "^4.1.5",
    "parcel": "^2.12.0",
    "prettier": "^3.3.3",
    "process": "^0.11.10",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.1",
    "url": "^0.11.3",
    "util": "^0.12.5"
  },
  "targets": {
    "client": {
      "source": [
        "client/pages/home.html",
        "client/pages/auth.html",
        "client/pages/map.html",
        "client/pages/account.html"
      ],
      "distDir": ".dist/client",
      "context": "browser"
    },
    "server": {
      "source": "server/serve.ts",
      "distDir": ".dist/server",
      "context": "node",
      "includeNodeModules": false
    }
  },
  "engines": {
    "node": "^20.16.0",
    "npm": ">=10.8.0"
  }
}
