{
  "name": "scottygo",
  "author": "",
  "license": "None",
  "version": "0.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cmu-fse/s26-fse-scottygo.git"
  },
  "scripts": {
    "clean:dist": "rm -rf ./.dist",
    "clean:all": "rm -rf ./.parcel-cache ./.dist",
    "build": "parcel build",
    "clean:build": "npm-run-all clean:all build",
    "start": "node ./.dist/server/serve",
    "watch": "nodemon --watch client --watch server --watch .env -e js,ts,html,pug,css,json --exec npm-run-all build start",
    "lint": "eslint ./",
    "pug": "ts-node ./tools/pug-compile",
    "serve": "ts-node server/serve",
    "later": "echo \"Some future command...\" && exit 1"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jquery": "^3.7.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.5.2",
    "pug": "^3.0.3",
    "socket.io": "^4.7.5",
    "socket.io-client": "^4.7.5",
    "uuid": "^10.0.0"
  },
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@parcel/transformer-pug": "^2.12.0",
    "@parcel/watcher": "^2.4.1",
    "@tsconfig/node-lts": "^20.1.3",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/http-terminator": "^2.0.5",
    "@types/jest": "^29.5.12",
    "@types/jquery": "^3.5.30",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.12",
    "@types/uuid": "^10.0.0",
    "assert": "^2.1.0",
    "buffer": "^6.0.3",
    "eslint": "^9.8.0",
    "globals": "^15.9.0",
    "http-terminator": "^3.2.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-expect-message": "^1.1.3",
    "nodemon": "^3.1.4",
    "npm": "^10.8.0",
    "npm-run-all": "^4.1.5",
    "parcel": "^2.12.0",
    "prettier": "^3.3.3",
    "process": "^0.11.10",
    "ts-jest": "^29.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.1",
    "url": "^0.11.3",
    "util": "^0.12.5"
  },
  "targets": {
    "client": {
      "source": [
        "client/pages/home.html",
        "client/pages/auth.html",
        "client/pages/app_directory.html"
      ],
      "distDir": ".dist/client",
      "context": "browser"
    },
    "server": {
      "source": "server/serve.ts",
      "distDir": ".dist/server",
      "context": "node",
      "includeNodeModules": false
    }
  },
  "engines": {
    "node": "^20.16.0",
    "npm": ">=10.8.0"
  }
}
