    "vid": "3516",
    "routeId": "61C",
    "crowdedness": "Empty",
    "lat": 40.419921875,
    "lon": -79.92830657958984
}
###

// ============================================================================
// ALTERNATIVE FLOW A19 — Inappropriate Comment Flagged (LLM moderation, R11)
// ============================================================================

// Submit a report with a comment that should be flagged by the LLM.
// Expected: 201 Created, ReportSubmitted; message indicates comment was flagged:
//   "Your comment was flagged and will not be included in the notification."
//   payload should NOT contain the comment field.
POST http://localhost:8080/notifications/reports
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiJmY2RlMDU1Zi1iMGEyLTRjZGMtOThmNC0xOGEzNjdkYWEwYjMiLCJ1c2VybmFtZSI6InRlc3R1c2VyMSIsImlhdCI6MTc3NTIyOTUxN30.EcL9b4j8ZpBnhl4_ENzaPvw2ocDPtaXcjC6YoRMFkCU

{
    "vid": "3516",
    "routeId": "61C",
    "crowdedness": "Standing Room",
    "comment": "This is an inappropriate and offensive comment!",
    "lat": 40.419921875,
    "lon": -79.92830657958984
}
###

// ============================================================================
// ALTERNATIVE FLOW A12 — No Matching Results
// ============================================================================

// Search for a route with no recent notifications.
