// REST tests for authentication services (register, login/logout)

// ============================================================================
// UC REGISTER - BASIC FLOW: Register a new user
// ============================================================================
// Member provides username, email, password → app validates → creates user
// Expected: 201 Created, returns new user with agreed=false
POST http://localhost:8080/auth/users
Content-Type: application/json

{
    "credentials": { 
        "username": "newmember",
        "password": "Test123!@"
    },
    "email": "newmember@cmu.edu",
    "agreed": false
}
###

// After registration, user agrees to terms via PATCH
// Expected: 200 OK, agreed updated to true
PATCH http://localhost:8080/auth/users/newmember
Content-Type: application/json

{
    "password": "Test123!@"
}
###

// ============================================================================
// UC REGISTER - A1: CanLogin (user already exists, correct password)
// ============================================================================
// Try to register with same username and correct password
// Expected: 400, UserExists - "please log in"
POST http://localhost:8080/auth/users
Content-Type: application/json

{
    "credentials": { 
        "username": "newmember",
        "password": "Test123!@"
    },
    "email": "newmember@cmu.edu",
    "agreed": false
}
###

// ============================================================================
// UC REGISTER - A2: EmailMissing (no email = assumed login, not register)
// ============================================================================

// Missing email field → should return error
// Expected: 400, MissingEmail
POST http://localhost:8080/auth/users
Content-Type: application/json

{
    "credentials": { 
        "username": "noemail",
        "password": "Test123!@"
    }
}
###

// ============================================================================
// UC REGISTER - A3: MemberExists (username exists, wrong password)
// ============================================================================

// Try to register with existing username but wrong password
// Expected: 400, InvalidUsername - "Please provide a different username"
POST http://localhost:8080/auth/users
Content-Type: application/json

{
    "credentials": { 
        "username": "newmember",
        "password": "WrongPass1!"
    },
    "email": "differentemail@cmu.edu",
    "agreed": false
}
###

// Same username, same email, wrong password (existing user mistyped password)
// Expected: 400, IncorrectPassword - "Re-enter username and/or password"
POST http://localhost:8080/auth/users
Content-Type: application/json

{
    "credentials": { 
        "username": "newmember",
        "password": "WrongPass1!"
    },
    "email": "newmember@cmu.edu",
    "agreed": false
}
###

// ============================================================================
// UC REGISTER - A4: UsernameInvalid (R1 - Username Rule violations)
// ============================================================================

// Username too short (less than 4 characters)
// Expected: 400, InvalidUsername - "at least 4 characters"
POST http://localhost:8080/auth/users
Content-Type: application/json

{
    "credentials": { 
        "username": "ab",
        "password": "Test123!@"
    },
    "email": "ab@cmu.edu",
    "agreed": false
}
###

// Username is a banned/reserved word
// Expected: 400, InvalidUsername - "invalid"
POST http://localhost:8080/auth/users
Content-Type: application/json

{
    "credentials": { 
        "username": "admin",
        "password": "Test123!@"
    },
    "email": "admin@cmu.edu",
    "agreed": false
}
###

// Missing username
// Expected: 400, MissingUsername
POST http://localhost:8080/auth/users
Content-Type: application/json

{
    "credentials": { 
        "password": "Test123!@"
    },
    "email": "nouser@cmu.edu",
    "agreed": false
}
###

// ============================================================================
// UC REGISTER - A5: PasswordInvalid (R2 - Password Rule violations)
// ============================================================================

// Password too short (less than 4 characters)
// Expected: 400, WeakPassword - "at least 4 characters"
POST http://localhost:8080/auth/users
Content-Type: application/json

{
    "credentials": { 
        "username": "weakpass1",
        "password": "Ab1"
    },
    "email": "weakpass1@cmu.edu",
    "agreed": false
}
###

// Password missing letters
// Expected: 400, WeakPassword - "at least one letter"
POST http://localhost:8080/auth/users
Content-Type: application/json

{
    "credentials": { 
        "username": "weakpass2",
        "password": "1234!@"
    },
    "email": "weakpass2@cmu.edu",
    "agreed": false
}
###

// Password missing numbers
// Expected: 400, WeakPassword - "at least one number"
POST http://localhost:8080/auth/users
Content-Type: application/json

{
    "credentials": { 
        "username": "weakpass3",
        "password": "Abcd!@"
    },
    "email": "weakpass3@cmu.edu",
    "agreed": false
}
###

// Password missing special characters
// Expected: 400, WeakPassword - "at least one special character"
POST http://localhost:8080/auth/users
Content-Type: application/json

{
    "credentials": { 
        "username": "weakpass4",
        "password": "Abcd12"
    },
    "email": "weakpass4@cmu.edu",
    "agreed": false
}
###

// Missing password
// Expected: 400, MissingPassword
POST http://localhost:8080/auth/users
Content-Type: application/json

{
    "credentials": { 
        "username": "nopass"
    },
    "email": "nopass@cmu.edu",
    "agreed": false
}
###

// ============================================================================
// UC REGISTER - A5 (second): Ineligible (R3 - non-CMU email)
// ============================================================================

// Email is not a CMU domain
// Expected: 400, InvalidEmail - "valid CMU email address"
POST http://localhost:8080/auth/users
Content-Type: application/json

{
    "credentials": { 
        "username": "outsider",
        "password": "Test123!@"
    },
    "email": "outsider@gmail.com",
    "agreed": false
}
###

// ============================================================================
// UC REGISTER - A7: Disagreement (user does not agree to terms)
// ============================================================================

// Register user who does not agree
// Expected: 201 Created with agreed=false
POST http://localhost:8080/auth/users
Content-Type: application/json

{
    "credentials": { 
        "username": "disagreer",
        "password": "Test123!@"
    },
    "email": "disagreer@cmu.edu",
    "agreed": false
}
###

// Try to login without agreeing - should be denied
// Expected: 401, UnauthorizedRequest
POST http://localhost:8080/auth/tokens/disagreer
Content-Type: application/json

{
    "password": "Test123!@"
}
###

// ============================================================================
// SETUP: Create test users for login/logout tests
// ============================================================================

// Create a registered user who agreed to terms
POST http://localhost:8080/auth/users
Content-Type: application/json

{
    "credentials": { 
        "username": "testuser1",
        "password": "Test123!@"
    },
    "email": "testuser1@cmu.edu",
    "agreed": true
}
###

// Create a registered user who has NOT agreed to terms (for A2 flow)
POST http://localhost:8080/auth/users
Content-Type: application/json

{
    "credentials": { 
        "username": "testuser2@cmu.edu",
        "password": "Test123!@"
    },
    "email": "testuser2@cmu.edu",
    "agreed": false
}
###

// ============================================================================
// BASIC FLOW: Login with existing user
// ============================================================================

// Step 3-4: Login with valid username and password (no email = login per R1)
// Expected: 200 OK, returns token, user marked online
POST http://localhost:8080/auth/tokens/testuser1@cmu.edu
Content-Type: application/json

{
    "password": "Test123!@"
}
###

// ============================================================================
// ALTERNATIVE FLOW A1: NonexistingMember (triggers registration)
// ============================================================================

// Login attempt with non-existing username
// Expected: 404 or error indicating user doesn't exist
POST http://localhost:8080/auth/tokens/nonexistent@cmu.edu
Content-Type: application/json

{
    "password": "Test123!@"
}
###

// ============================================================================
// ALTERNATIVE FLOW A2: User exists but hasn't agreed to terms
// ============================================================================

// Login with user who hasn't agreed to terms
// Expected: Returns user with agreed=false, frontend shows terms modal
POST http://localhost:8080/auth/tokens/testuser2@cmu.edu
Content-Type: application/json

{
    "password": "Test123!@"
}
###

// Update agreement after user accepts terms
PATCH http://localhost:8080/auth/users/testuser2@cmu.edu?agreed=true
Content-Type: application/json

{
    "password": "Test123!@"
}
###

// ============================================================================
// RULE R1: OnlyUsernamePassword - Email triggers Register
// ============================================================================

// If email is provided, this should trigger registration flow, not login
// This test verifies that the frontend sends appropriate data
// (Frontend logic: email field empty = login, email field filled = register)

// ============================================================================
// ERROR CASES: Login failures
// ============================================================================

// Missing password
POST http://localhost:8080/auth/tokens/testuser1@cmu.edu
Content-Type: application/json

{
}
###

// Wrong password
POST http://localhost:8080/auth/tokens/testuser1
Content-Type: application/json

{
    "password": "WrongPassword123!"
}
###

// Empty username in URL
POST http://localhost:8080/auth/tokens/
Content-Type: application/json

{
    "password": "Test123!@"
}
###
