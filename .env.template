# This is a template - don't change or delete it.
# Create a new file .env and copy the required content to that file. 

#
# The PORT setting is used for localhost and codespace host only
PORT=8080
#

#
# HOST URLs: set these to the URLs used in different build environments and servers
LOCAL_HOST=http://localhost
CODESPACE_HOST=PLEASE POPULATE IN YOUR OWN .ENV FILE WITH YOUR CODESPACE URL
RENDER_HOST=https://s26-fse-scottygo.onrender.com
#

#
# ENV: LOCAL | CODESPACE | RENDER, depending on the build environment
ENV=CODESPACE
#

# STAGE:  EARLY | DEV | PROD, depending on the development stage 
STAGE=DEV

#
# JWT_KEY is a random string you generated
JWT_KEY=PLEASE POPULATE IN YOUR OWN .ENV FILE WITH WHAT GEORGE HAS PROVIDED YOU
#

# JWT_EXP is the expiration time of the JWT token when ENV = PROD
JWT_EXP=365d

#
# Email Configuration (Gmail SMTP)
# Get app password from: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
EMAIL_FROM_NAME=ScottyGO
#

# DB_URL is the url to your mongodb Atlas DB without the DB subpath
# It has the following format:
# mongodb+srv://<mongoDB_Username>:<mongDB_password>@<cluster_path>.mongodb.net
# DB subpath is added to the url by the app later depending on the STAGE 
DB_URL=PLEASE POPULATE IN YOUR OWN .ENV FILE WITH YOUR MONGODB ATLAS CONNECTION STRING
#

# PROD_DB and DEV_DB are mongodb Atlas db subpaths for STAGE = PROD and STAGE = DEV
# in this format: /<db_name>?retryWrites=true&w=majority
PROD_DB=/ScottyGoPROD?retryWrites=true&w=majority&appName=Cluster0
DEV_DB=/ScottyGoDEV?retryWrites=true&w=majority&appName=Cluster0

# Make sure the DB_URL + PROD_DB and DB_URL + DEV_DB doesn't have 
# a double forward slash (//) in the path part of the URL string

#
# TrueTime API (Pittsburgh Regional Transit)
# Get your API key from: https://truetime.portauthority.org
TRUETIME_KEY=PLEASE POPULATE IN YOUR OWN .ENV FILE WITH YOUR TRUETIME API KEY
TRUETIME_BASE_URL=https://truetime.portauthority.org/bustime/api/v3
#

#
# Google Maps API key
# Get your API key from: https://console.cloud.google.com/apis/credentials
GOOGLE_MAPS_KEY=PLEASE POPULATE IN YOUR OWN .ENV FILE WITH YOUR GOOGLE MAPS API KEY
#
