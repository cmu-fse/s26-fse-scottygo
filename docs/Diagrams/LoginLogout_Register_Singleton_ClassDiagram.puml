@startuml
skinparam classAttributeIconSize 0

title LoginLogout/Register - Singleton Design Pattern

class Serve <<Client>> {
  +bootstrap() : void
}

class AuthController <<Singleton>> {
  -{static} instance : AuthController
  -AuthController(path : string)
  +{static} getInstance(path : string) : AuthController
}

Serve ..> AuthController : uses getInstance("/auth")

@enduml
